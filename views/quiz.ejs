<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <main class="page-shell quiz-shell fade-in">
    <section class="page-heading">
      <p class="eyebrow">Server Quiz</p>
      <h1>Reze Blox YT Quiz</h1>
      <p class="warning-note">You can only submit once. Review carefully before final submission.</p>
      <p class="warning-note danger-warning">⚠️ DO NOT switch tabs or windows. Doing so will instantly submit your quiz with a score of 0/20.</p>
    </section>

    <section class="glass-card quiz-card" aria-live="polite">
      <div class="quiz-topline">
        <span id="questionCounter">Question 1 / <%= questions.length %></span>
        <span id="answeredCounter">0 answered</span>
      </div>

      <div class="progress-track" aria-label="Quiz progress">
        <div id="progressFill" class="progress-fill"></div>
      </div>

      <div id="quizQuestionArea" class="quiz-question-area">
        <!-- quiz.js renders the current question here. -->
      </div>

      <p id="quizMessage" class="error-text quiz-message" role="alert"></p>

      <div class="quiz-actions">
        <button id="prevBtn" class="btn btn-ghost" type="button">Previous</button>
        <button id="nextBtn" class="btn btn-secondary" type="button">Next</button>
        <button id="submitQuizBtn" class="btn btn-primary" type="button">Final Submit</button>
      </div>
    </section>
  </main>

  <div id="cheatOverlay" class="cheat-overlay hidden" role="alert" aria-live="assertive">
    <div>
      <strong>CHEATING DETECTED</strong>
      <p>Your submission has been locked with a score of 0/20.</p>
      <p class="cheat-countdown-line">Redirecting to credits in <span id="cheatCountdown">3</span>...</p>
    </div>
  </div>

  <script>
    // Server sends real questions without correctAnswer.
    // The answer key stays server-side only.
    window.QUIZ_QUESTIONS = <%- JSON.stringify(questions) %>;
  </script>
  <script src="/js/quiz.js?v=phase4-final-fix"></script>
  <%- include('partials/footer') %>
</body>
</html>
