# Copy this file to .env for local development.
# Never commit real secrets to GitHub.

PORT=3000
NODE_ENV=development

# Discord OAuth2 settings from the Discord Developer Portal.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Used by express-session to sign the login cookie.
# Use a long random value in the real .env file.
SESSION_SECRET=

# Supabase settings.
# Use the service role key on the backend only. Never expose it in frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
